{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Faithful Upscaler",
  "version": "0.1.0",
  "identifier": "com.codex.faithful-upscaler",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Faithful Upscaler",
        "width": 980,
        "height": 760,
        "minWidth": 860,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
